	title = {Georgia blaze shows how climate change has led to more wildfires in the {East}},
	url = {https://apnews.com/article/wildfire-georgia-east-west-climate-change-helene-9dff2248c09a709c0d03053378210722},
	abstract = {Often considered more a problem for Western North America, wildfires are becoming more intense, frequent and damaging in the East, such as this week’s blaze that destroyed dozens of homes in Georgia, fire scientists said. Researchers blame a number of factors including climate change causing fuel to dry out and be more flammable, a record drought, tens of millions of tons of dead trees from Hurricane Helene and just the large area where dense forests and high numbers of people try to coexist.},
	urldate = {2026-04-28},
