# Use a flat (hoisted) node_modules layout instead of pnpm's symlinked store.
# Hugo 0.162.1 cannot resolve the Tailwind CLI through pnpm's .pnpm shim, failing
# with: binary "tailwindcss" is not a Node.js script (gohugoio/hugo#14852).
# A hoisted layout matches npm's, which Hugo resolves correctly.
node-linker=hoisted
