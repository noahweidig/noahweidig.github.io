<%
// Inline <svg> gets mangled by the listing pipeline (child <path> tags are
// escaped), so icons live as standalone files in assets/media/icons/projects/
// and are referenced by <img>. One unique icon per project slug.
const nwProjGrads = {
  'chartifyr':      'g-sky',
  'dataviz':        'g-fuchsia',
  'faststats':      'g-amber',
  'firer':          'g-rose',
  'framelab':       'g-sky',
  'imagestudio':    'g-fuchsia',
  'less':           'g-lime',
  'lorem-chartsum': 'g-amber',
  'maplab':         'g-emerald',
  'maps':           'g-sky',
  'quickplot':      'g-rose',
  'r-proj-template':'g-amber',
  'roads':          'g-emerald',
  'shelf':          'g-lime',
  'wildfire':       'g-rose',
  'wordcloud':      'g-sky',
  'wuirisk':        'g-amber'
};
%>
```{=html}
<% for (const item of items) { %>
<%
const nwSegs = String(item.path).split('/').filter(Boolean);
const nwSlug = nwSegs.length > 1 ? nwSegs[nwSegs.length - 2] : nwSegs[0];
const nwGrad = nwProjGrads[nwSlug] || 'g-sky';
const nwIconSrc = '/assets/media/icons/projects/' + (nwProjGrads[nwSlug] ? nwSlug : 'default') + '.svg';
%>
<div class="nw-proj-wrap">
<div class="nw-proj-card" data-cats="<%= (item.categories || []).join('|') %>">
<a class="nw-proj-media" href="<%- item.path %>" aria-label="<%= item.title %>"><span class="nw-icon <%= nwGrad %>"><img src="<%= nwIconSrc %>" alt="" loading="lazy"></span></a>
<div class="nw-proj-body">
<h3><a href="<%- item.path %>"><%= item.title %></a></h3>
<p><%= item.description || '' %></p>
<div class="nw-chips">
<% for (const c of (item.categories || [])) { %><span class="nw-chip"><%= c %></span><% } %>
</div>
</div>
</div>
</div>
<% } %>
```
