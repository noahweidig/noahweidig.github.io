```{=html}
<% for (const item of items) { %>
<%
const nwSegs = String(item.path).split('/').filter(Boolean);
const nwSlug = nwSegs.length > 1 ? nwSegs[nwSegs.length - 2] : nwSegs[0];
const nwIcon = nwProjIcons[nwSlug] || { g: 'g-sky', svg: '<path d="M12 3l8 4.5v9l-8 4.5l-8 -4.5v-9z"/><path d="M12 12l8 -4.5"/><path d="M12 12v9"/><path d="M12 12l-8 -4.5"/>' };
%>
<div class="nw-proj-wrap">
<div class="nw-proj-card" data-cats="<%= (item.categories || []).join('|') %>">
<a class="nw-proj-media" href="<%- item.path %>" aria-label="<%= item.title %>"><span class="nw-icon <%= nwIcon.g %>"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><%- nwIcon.svg %></svg></span></a>
<div class="nw-proj-body">
<h3><a href="<%- item.path %>"><%= item.title %></a></h3>
<p><%= item.description || '' %></p>
<div class="nw-chips">
<% for (const c of (item.categories || [])) { %><span class="nw-chip"><%= c %></span><% } %>
</div>
</div>
</div>
</div>
<% } %>
```
